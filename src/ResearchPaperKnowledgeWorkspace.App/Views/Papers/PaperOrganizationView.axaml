<UserControl
    x:Class="ResearchPaperKnowledgeWorkspace.App.Views.Papers.PaperOrganizationView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:ResearchPaperKnowledgeWorkspace.App.ViewModels.Papers"
    x:DataType="vm:PaperOrganizationViewModel">

    <Grid RowDefinitions="Auto,Auto,*">
        <Grid
            Grid.Row="0"
            Margin="0,0,0,12"
            ColumnDefinitions="*,Auto,Auto,Auto">

            <StackPanel>
                <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="Knowledge Organization" />

                <TextBlock
                    Opacity="0.7"
                    Text="{Binding DirtyStateText}" />
            </StackPanel>

            <Button
                Grid.Column="1"
                Margin="0,0,8,0"
                Command="{Binding RefreshCatalogCommand}"
                Content="Refresh Catalog" />

            <Button
                Grid.Column="2"
                Margin="0,0,8,0"
                Command="{Binding RevertCommand}"
                Content="Revert" />

            <Button
                Grid.Column="3"
                Command="{Binding SaveCommand}"
                Content="Save Organization" />
        </Grid>

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,12"
            Spacing="8">

            <Border
                IsVisible="{Binding HasError}"
                Padding="10"
                BorderBrush="#C84A4A"
                BorderThickness="1"
                CornerRadius="6">

                <TextBlock
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap" />
            </Border>

            <Border
                IsVisible="{Binding HasStatusMessage}"
                Padding="10"
                BorderBrush="#4B8A57"
                BorderThickness="1"
                CornerRadius="6">

                <TextBlock
                    Text="{Binding StatusMessage}"
                    TextWrapping="Wrap" />
            </Border>
        </StackPanel>

        <TabControl Grid.Row="2">
            <TabItem Header="Authors">
                <Grid
                    Margin="8"
                    RowDefinitions="Auto,*">

                    <Grid
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        ColumnDefinitions="2*,*,2*,Auto">

                        <TextBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Text="{Binding NewAuthorName, Mode=TwoWay}"
                            PlaceholderText="Author full name" />

                        <TextBox
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            Text="{Binding NewAuthorOrcid, Mode=TwoWay}"
                            PlaceholderText="ORCID" />

                        <TextBox
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            Text="{Binding NewAuthorAffiliation, Mode=TwoWay}"
                            PlaceholderText="Affiliation" />

                        <Button
                            Grid.Column="3"
                            Command="{Binding CreateAuthorCommand}"
                            Content="Create Author" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Authors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate
                                    x:DataType="vm:AuthorSelectionItemViewModel">

                                    <Border
                                        Padding="8"
                                        BorderBrush="Gray"
                                        BorderThickness="0,0,0,1">

                                        <CheckBox
                                            IsEnabled="{Binding $parent[UserControl].DataContext.HasPaper}"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay}">

                                            <StackPanel>
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding FullName}" />

                                                <TextBlock
                                                    Opacity="0.65"
                                                    Text="{Binding Affiliation}" />
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Tags">
                <Grid
                    Margin="8"
                    RowDefinitions="Auto,*">

                    <Grid
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        ColumnDefinitions="*,2*,*,Auto">

                        <TextBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Text="{Binding NewTagName, Mode=TwoWay}"
                            PlaceholderText="Tag name" />

                        <TextBox
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            Text="{Binding NewTagDescription, Mode=TwoWay}"
                            PlaceholderText="Description" />

                        <TextBox
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            Text="{Binding NewTagColorHex, Mode=TwoWay}"
                            PlaceholderText="#4A90E2" />

                        <Button
                            Grid.Column="3"
                            Command="{Binding CreateTagCommand}"
                            Content="Create Tag" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Tags}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate
                                    x:DataType="vm:TagSelectionItemViewModel">

                                    <CheckBox
                                        Margin="4"
                                        IsEnabled="{Binding $parent[UserControl].DataContext.HasPaper}"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                        Content="{Binding Name}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <TabItem Header="Projects">
                <Grid
                    Margin="8"
                    RowDefinitions="Auto,*">

                    <Grid
                        Grid.Row="0"
                        Margin="0,0,0,12"
                        ColumnDefinitions="*,2*,150,*,Auto">

                        <TextBox
                            Grid.Column="0"
                            Margin="0,0,8,0"
                            Text="{Binding NewProjectName, Mode=TwoWay}"
                            PlaceholderText="Project name" />

                        <TextBox
                            Grid.Column="1"
                            Margin="0,0,8,0"
                            Text="{Binding NewProjectDescription, Mode=TwoWay}"
                            PlaceholderText="Description" />

                        <ComboBox
                            Grid.Column="2"
                            Margin="0,0,8,0"
                            ItemsSource="{Binding ProjectStatusOptions}"
                            SelectedItem="{Binding NewProjectStatus, Mode=TwoWay}" />

                        <TextBox
                            Grid.Column="3"
                            Margin="0,0,8,0"
                            Text="{Binding NewProjectColorHex, Mode=TwoWay}"
                            PlaceholderText="#7B61FF" />

                        <Button
                            Grid.Column="4"
                            Command="{Binding CreateProjectCommand}"
                            Content="Create Project" />
                    </Grid>

                    <ScrollViewer Grid.Row="1">
                        <ItemsControl ItemsSource="{Binding Projects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate
                                    x:DataType="vm:ProjectSelectionItemViewModel">

                                    <Border
                                        Padding="8"
                                        BorderBrush="Gray"
                                        BorderThickness="0,0,0,1">

                                        <CheckBox
                                            IsEnabled="{Binding $parent[UserControl].DataContext.HasPaper}"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay}">

                                            <StackPanel>
                                                <TextBlock
                                                    FontWeight="SemiBold"
                                                    Text="{Binding Name}" />

                                                <TextBlock
                                                    Opacity="0.65"
                                                    Text="{Binding Status}" />
                                            </StackPanel>
                                        </CheckBox>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>